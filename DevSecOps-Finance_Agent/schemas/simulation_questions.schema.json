{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Security Incident Simulation Questions",
  "description": "Finance Agent가 MCP에 전달하는 시뮬레이션 질문 목록. MCP는 Slack Block Kit UI로 변환.",
  "type": "object",
  "additionalProperties": false,
  "required": ["simulation_questions"],
  "properties": {
    "simulation_questions": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "type", "options"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["environment", "data_sensitivity", "downtime_tolerance", "priority"]
          },
          "question": { "type": "string" },
          "type": { "type": "string", "const": "choice" },
          "options": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      }
    }
  }
}
