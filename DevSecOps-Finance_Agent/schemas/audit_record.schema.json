{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_id",
    "created_at",
    "engine_version",
    "policy_version",
    "policy_hash",
    "assumption_hash",
    "request",
    "scores",
    "recommendations",
    "insights"
  ],
  "properties": {
    "audit_id": { "type": "string", "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "engine_version": { "type": "string" },
    "policy_version": { "type": "string" },
    "policy_hash": { "type": "string" },
    "assumption_hash": { "type": "string" },
    "request": { "type": "object" },
    "scores": {
      "type": "object",
      "required": ["impact_breakdown", "likelihood", "regulatory_component", "profile_applied", "final_score"],
      "additionalProperties": false,
      "properties": {
        "impact_breakdown": { "type": "object" },
        "likelihood": { "type": "number" },
        "regulatory_component": { "type": "number" },
        "profile_applied": { "type": "string" },
        "final_score": { "type": "number" }
      }
    },
    "recommendations": {
      "type": "object",
      "required": ["top_actions", "forbidden_actions"],
      "additionalProperties": false,
      "properties": {
        "top_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["action_id", "rank", "score"],
            "properties": {
              "action_id": { "type": "string" },
              "rank": { "type": "integer", "minimum": 1 },
              "score": { "type": "number" }
            }
          }
        },
        "forbidden_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["action_id", "constraint_id", "reason_code"],
            "properties": {
              "action_id": { "type": "string" },
              "constraint_id": { "type": "string" },
              "reason_code": { "type": "string" }
            }
          }
        }
      }
    },
    "insights": {
      "type": "object",
      "required": ["top_drivers", "sensitivity", "tradeoffs"],
      "additionalProperties": false,
      "properties": {
        "top_drivers": { "type": "array", "items": { "type": "string" } },
        "sensitivity": { "type": "array" },
        "tradeoffs": { "type": "array" }
      }
    }
  }
}
