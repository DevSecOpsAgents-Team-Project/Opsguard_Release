{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Simulation Recommendation Result (MCP 전달용, 신규)",
  "description": "get_simulation_recommendation / get_simulation_recommendation_from_regulation 공통 응답 body",
  "type": "object",
  "additionalProperties": true,
  "required": ["user_response", "result", "xai", "validation"],
  "properties": {
    "playbook_scenario": { "type": "string" },
    "user_profile": { "type": "string" },
    "user_response": {
      "type": "object",
      "properties": {
        "environment": { "type": "string" },
        "data_sensitivity": { "type": "string" },
        "downtime_tolerance": { "type": "string" },
        "priority": { "type": "string" }
      }
    },
    "result": {
      "type": "object",
      "required": ["source", "recommended_level", "playbook_name", "reason"],
      "properties": {
        "source": { "type": "string", "enum": ["llm", "fallback"] },
        "recommended_level": { "type": "integer", "enum": [2, 3] },
        "playbook_name": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "xai": {
      "type": "object",
      "required": [
        "decision_trace",
        "decision_factors",
        "cost_comparison",
        "candidate_summary",
        "excluded_candidates",
        "applied_rules",
        "confidence_hint",
        "reason_alignment"
      ]
    },
    "validation": { "type": "string" }
  }
}
